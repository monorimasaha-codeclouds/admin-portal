{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.js"
    }
  ],
  "functions": {
    "backend/src/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
